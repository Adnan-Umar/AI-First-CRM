APP_NAME=AI-First CRM API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
# PostgreSQL connection. Adjust user/password/db to match your local Postgres.
# A database named ai_first_crm must already exist (created with `createdb ai_first_crm`).
DATABASE_URL=postgresql+psycopg://postgres@localhost:5432/ai_first_crm
DB_AUTO_CREATE=false

# Required for full AI routing. Without it the agent runs in demo mode (intent heuristics only).
GROQ_API_KEY=

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
