# Variables consumed by docker-compose.yml (copy to .env and adjust).
# The backend image published to Docker Hub by CI/CD also reads GROQ_API_KEY at runtime.

POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_pass
POSTGRES_DB=ai_first_crm

# Required for real LLM behavior (Groq gemma2-9b-it). Leave empty for demo mode.
GROQ_API_KEY=
# Primary Groq model (override to swap models; defaults to gemma2-9b-it).
GROQ_MODEL=gemma2-9b-it

# Base URL baked into the React build so the browser can reach the API.
VITE_API_BASE_URL=http://localhost:8000/api/v1
